# Copy this file to .env on the Ascend server only, then fill real SMTP values.
# Do not commit .env.

AK_COMM_SMTP_HOST=smtp.163.com
AK_COMM_SMTP_PORT=465
AK_COMM_SMTP_USER=your_163_account@163.com
AK_COMM_SMTP_PASSWORD=your_163_smtp_authorization_code
AK_COMM_MAIL_FROM=your_163_account@163.com
AK_COMM_MAIL_TO=gwlee1995@gmail.com

# Ascend server defaults.
AK_COMM_USE_PROXYCHAINS=1
AK_COMM_PROXYCHAINS_BIN=proxychains4
AK_COMM_PAYLOAD_DIR=/tmp
